# BM Planning — Go server environment variables
# Copy to .env and adjust (optional — defaults exist)

# HTTP listen port
PORT=8080

# CORS allowed origins (comma-separated). ALLOWED_ORIGINS takes precedence over CORS_ORIGINS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# ALLOWED_ORIGINS=https://planning.example.com

# Room lifecycle
ROOM_TTL=4h
ROOM_GRACE_AFTER_DISCONNECT=1h
MAX_PARTICIPANTS=50

# HTTP rate limit for /api/v1/* (requests per minute per IP)
HTTP_RATE_LIMIT_PER_MIN=60

# Optional: Redis for multi-instance room state (future)
# REDIS_URL=redis://localhost:6379

# WebSocket rate limit (10 msg/s per client) — configurable in a future release
